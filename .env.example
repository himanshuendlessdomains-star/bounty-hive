# BountyHive Frontend Environment Variables
# Set these in Vercel Project Settings → Environment Variables

# Backend API URL (required for production)
VITE_API_URL=https://bounty-hive.onrender.com/api

# TON network: "testnet" or "mainnet"
VITE_TON_NETWORK=mainnet

# BountyFactory contract address (deployed on mainnet)
VITE_FACTORY_ADDRESS=

# TON Center API key (mainnet)
VITE_TONCENTER_API_KEY=

# Telegram bot URL for the "Open in Telegram" gate
VITE_TELEGRAM_BOT_URL=https://t.me/bountyhive24_bot/bountyhive24
