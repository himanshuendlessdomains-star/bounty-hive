        throw_unless(63248, ( (__tact_slice_eq($msg'verification, __gen_slice_string_3728345577d9175dc9c0490a3886394391baecc8146b746d3b8ac6f14c93121d())) ? (true) : (__tact_slice_eq($msg'verification, __gen_slice_string_5d9ddc2d8d51d37ba48d50ea85601098279b4c9d3cdff063b172304b0bb9da1a())) ));
        var ($escrow'code, $escrow'data) = $BountyEscrow$_init_child(__tact_context_get_sender(), $msg'title, $msg'description, $msg'bountyType, $poolAmount, $msg'winnerCount, $msg'winnerSelection, $msg'verification, $msg'verificationRule, $self'platformFeeBps, $self'platformAddress, $global_now());
